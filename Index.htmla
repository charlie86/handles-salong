<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HS - Handles Salong</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background-color: #0a0a0a; color: #ffffff; font-family: 'Georgia', serif; }
        nav { display: flex; justify-content: space-between; align-items: center; padding: 20px 50px; border-bottom: 1px solid #2a2a2a; }
        nav h1 { color: #ffffff; font-size: 24px; letter-spacing: 4px; }
        nav ul { list-style: none; display: flex; gap: 30px; }
        nav ul li a { color: #aaaaaa; text-decoration: none; letter-spacing: 2px; font-size: 13px; }
        .hero { height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; border-bottom: 1px solid #2a2a2a; }
        .hero h2 { font-size: 60px; letter-spacing: 8px; margin-bottom: 20px; }
        .hero p { color: #4a9e6b; letter-spacing: 4px; font-size: 14px; margin-bottom: 40px; }
        .btn { padding: 15px 40px; border: 1px solid #4a9e6b; color: #4a9e6b; text-decoration: none; letter-spacing: 3px; font-size: 12px; transition: all 0.3s; }
        .btn:hover { background-color: #4a9e6b; color: #0a0a0a; }
    </style>
</head>
<body>
    <nav>
        <h1>HS</h1>
        <ul>
            <li><a href="#">SERVICES</a></li>
            <li><a href="#">GALLERY</a></li>
            <li><a href="#">CONTACT</a></li>
        </ul>
    </nav>
    <section class="hero">
        <h2>HANDLES SALONG</h2>
        <p>PRECISION CUTS · FALUN · EST. 2024</p>
        <a href="#" class="btn">BOOK NOW</a>
    </section>
</body>
</html>
